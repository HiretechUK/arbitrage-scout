# -----------------------------------------------
# Arbitrage Scout — Configuration
# Copy this file to .env and fill in your values
# -----------------------------------------------

# REQUIRED: Your Apify API token
# Get it from: https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXX

# OPTIONAL: Email alerts
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=your@gmail.com

# OPTIONAL: Slack/Discord/Make webhook URL for alerts
# Discord: https://discord.com/api/webhooks/...
# Slack:   https://hooks.slack.com/services/...
WEBHOOK_URL=

# API server port (default: 5050)
PORT=5050
